{
  "name": "Fullfin — Controle Financeiro",
  "short_name": "Fullfin",
  "description": "Controle financeiro do Escritório Naiarha",
  "start_url": "/fullfin/",
  "scope": "/fullfin/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#064E3B",
  "theme_color": "#064E3B",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/fullfin/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": ["image/*", "application/pdf", "application/octet-stream", "*/*"]
        }
      ]
    }
  }
}
